@using QuanLyKhoaHoc.Models
@model List<BaiViet>
@{
    ViewData["Title"] = "Tin tức & Sự kiện";
    int page = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="container py-4">
    <!-- Header -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h4 class="fw-bold mb-1"><i class="bi bi-newspaper text-primary me-2"></i>Tin tức &amp; Sự kiện</h4>
            <p class="text-muted small mb-0">Cập nhật những thông tin mới nhất từ EduCenter – <strong>@ViewBag.Total</strong> bài viết</p>
        </div>
    </div>

    <!-- Bộ lọc -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-3">
            <form method="get" action="/TinTuc" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" name="search" class="form-control" value="@ViewBag.Search" placeholder="Tìm kiếm bài viết...">
                    </div>
                </div>
                <div class="col-md-4">
                    <select name="theLoai" class="form-select">
                        <option value="">Tất cả thể loại</option>
                        @foreach (var tl in (ViewBag.DanhSachTheLoai as List<string> ?? new()))
                        {
                            <option value="@tl" selected="@(ViewBag.TheLoai == tl)">@tl</option>
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-fill"><i class="bi bi-funnel me-1"></i>Lọc</button>
                    <a href="/TinTuc" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i></a>
                </div>
            </form>
        </div>
    </div>

    <!-- Danh sách bài viết -->
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-newspaper fs-1"></i>
            <h5 class="mt-3">Chưa có bài viết nào</h5>
            <a href="/TinTuc" class="btn btn-primary mt-3">Xem tất cả</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var b in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <a href="/TinTuc/@b.Id" class="text-decoration-none text-dark">
                        <div class="card border-0 shadow-sm h-100">
                            @if (!string.IsNullOrEmpty(b.HinhAnh))
                            {
                                <img src="@b.HinhAnh" class="card-img-top" style="height:190px;object-fit:cover" alt="@b.TieuDe"
                                     onerror="this.style.display='none'">
                            }
                            else
                            {
                                <div class="card-img-top bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="height:190px">
                                    <i class="bi bi-newspaper text-primary" style="font-size:3rem"></i>
                                </div>
                            }
                            <div class="card-body p-3">
                                <div class="d-flex gap-2 mb-2 flex-wrap">
                                    <span class="badge bg-primary bg-opacity-10 text-primary small">@b.TheLoai</span>
                                    @if (b.NoiBat)
                                    {
                                        <span class="badge bg-warning text-dark small"><i class="bi bi-star-fill me-1"></i>Nổi bật</span>
                                    }
                                </div>
                                <h6 class="fw-bold mb-2 lh-sm">@b.TieuDe</h6>
                                @if (!string.IsNullOrEmpty(b.TomTat))
                                {
                                    <p class="text-muted small mb-0" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">@b.TomTat</p>
                                }
                            </div>
                            <div class="card-footer bg-transparent border-0 d-flex justify-content-between align-items-center pt-0 pb-3 px-3">
                                <small class="text-muted">
                                    <i class="bi bi-person me-1"></i>@(string.IsNullOrEmpty(b.TacGia) ? "EduCenter" : b.TacGia)
                                </small>
                                <small class="text-muted">
                                    <i class="bi bi-calendar me-1"></i>@b.NgayTao.ToString("dd/MM/yyyy")
                                    <span class="ms-2"><i class="bi bi-eye me-1"></i>@b.LuotXem</span>
                                </small>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <nav class="mt-4 d-flex justify-content-center">
                <ul class="pagination">
                    <li class="page-item @(page <= 1 ? "disabled" : "")">
                        <a class="page-link" href="?page=@(page-1)&theLoai=@ViewBag.TheLoai&search=@ViewBag.Search">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == page ? "active" : "")">
                            <a class="page-link" href="?page=@i&theLoai=@ViewBag.TheLoai&search=@ViewBag.Search">@i</a>
                        </li>
                    }
                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="?page=@(page+1)&theLoai=@ViewBag.TheLoai&search=@ViewBag.Search">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>
