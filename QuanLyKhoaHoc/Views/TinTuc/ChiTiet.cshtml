@using QuanLyKhoaHoc.Models
@model BaiViet
@{
    ViewData["Title"] = Model.TieuDe;
    var lienQuan = ViewBag.LienQuan as List<BaiViet> ?? new();
}

<div class="container py-4">
    <div class="row g-4">
        <!-- Main article -->
        <div class="col-lg-8">
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="/TinTuc">Tin tức</a></li>
                    <li class="breadcrumb-item active text-truncate" style="max-width:200px">@Model.TieuDe</li>
                </ol>
            </nav>

            <article class="card border-0 shadow-sm">
                @if (!string.IsNullOrEmpty(Model.HinhAnh))
                {
                    <img src="@Model.HinhAnh" class="card-img-top" style="height:350px;object-fit:cover" alt="@Model.TieuDe"
                         onerror="this.style.display='none'">
                }
                <div class="card-body p-4">
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2">@Model.TheLoai</span>
                        @if (Model.NoiBat)
                        {
                            <span class="badge bg-warning text-dark px-3 py-2"><i class="bi bi-star-fill me-1"></i>Nổi bật</span>
                        }
                    </div>

                    <h2 class="fw-bold mb-3">@Model.TieuDe</h2>

                    <div class="d-flex flex-wrap gap-3 text-muted small mb-4 pb-3 border-bottom">
                        <span><i class="bi bi-person me-1"></i>@(string.IsNullOrEmpty(Model.TacGia) ? "EduCenter" : Model.TacGia)</span>
                        <span><i class="bi bi-calendar me-1"></i>@Model.NgayTao.ToString("dd/MM/yyyy HH:mm")</span>
                        <span><i class="bi bi-eye me-1"></i>@Model.LuotXem lượt xem</span>
                        @if (Model.NgayCapNhat.HasValue)
                        {
                            <span><i class="bi bi-pencil me-1"></i>Cập nhật: @Model.NgayCapNhat.Value.ToString("dd/MM/yyyy")</span>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(Model.TomTat))
                    {
                        <div class="alert alert-primary border-0 bg-primary bg-opacity-10 mb-4">
                            <p class="mb-0 fw-semibold">@Model.TomTat</p>
                        </div>
                    }

                    <div class="article-content lh-lg">
                        @Html.Raw(Model.NoiDung?.Replace("\n", "<br>") ?? "")
                    </div>
                </div>

                <div class="card-footer bg-transparent border-0 p-4 pt-0">
                    <div class="d-flex gap-2 flex-wrap">
                        <a href="/TinTuc" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-arrow-left me-1"></i>Quay lại
                        </a>
                        <a href="/TinTuc?theLoai=@Uri.EscapeDataString(Model.TheLoai)" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-tag me-1"></i>@Model.TheLoai
                        </a>
                    </div>
                </div>
            </article>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            @if (lienQuan.Any())
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent border-0 pb-0 pt-3 px-3">
                        <h6 class="fw-bold mb-0"><i class="bi bi-link-45deg text-primary me-2"></i>Bài viết liên quan</h6>
                    </div>
                    <div class="card-body p-3">
                        @foreach (var b in lienQuan)
                        {
                            <a href="/TinTuc/@b.Id" class="text-decoration-none text-dark d-flex gap-3 mb-3 pb-3 border-bottom">
                                @if (!string.IsNullOrEmpty(b.HinhAnh))
                                {
                                    <img src="@b.HinhAnh" style="width:72px;height:54px;object-fit:cover;border-radius:8px;flex-shrink:0" alt="" onerror="this.style.display='none'">
                                }
                                <div>
                                    <div class="fw-semibold small lh-sm mb-1" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">@b.TieuDe</div>
                                    <div class="text-muted" style="font-size:.7rem">@b.NgayTao.ToString("dd/MM/yyyy")</div>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }

            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body p-3 text-center">
                    <i class="bi bi-book-half text-primary" style="font-size:2.5rem"></i>
                    <h6 class="fw-bold mt-2 mb-1">Khám phá khóa học</h6>
                    <p class="text-muted small mb-3">Đăng ký học ngay hôm nay</p>
                    <a href="/KhoaHoc" class="btn btn-primary btn-sm w-100">
                        <i class="bi bi-search me-1"></i>Xem khóa học
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
