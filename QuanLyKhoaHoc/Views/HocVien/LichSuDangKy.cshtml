@{
    ViewData["Title"] = "Khóa học của tôi";
    Layout = "_Layout";
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between gap-3 mb-4 flex-wrap">
        <div class="d-flex align-items-center gap-3">
            <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center" style="width:48px;height:48px">
                <i class="bi bi-book-half text-success fs-4"></i>
            </div>
            <div>
                <h4 class="mb-0 fw-bold">Khóa học của tôi</h4>
                <p class="text-muted mb-0 small">Tất cả khóa học bạn đã đăng ký</p>
            </div>
        </div>
        <a href="/KhoaHoc" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i>Đăng ký thêm
        </a>
    </div>

    <!-- Banner thanh toán chờ xử lý -->
    <div id="pendingPaymentBanner" class="d-none mb-3"></div>

    <div id="loadingState" class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="text-muted mt-2">Đang tải dữ liệu...</p>
    </div>

    <div id="emptyState" class="text-center py-5 d-none">
        <i class="bi bi-inbox text-muted" style="font-size:3rem"></i>
        <h5 class="mt-3 text-muted">Bạn chưa đăng ký khóa học nào</h5>
        <a href="/KhoaHoc" class="btn btn-primary mt-3">
            <i class="bi bi-search me-2"></i>Khám phá khóa học
        </a>
    </div>

    <div id="dangKyContainer" class="d-none">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pb-0">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div class="d-flex gap-2 flex-wrap" id="filterBtns">
                        <button class="btn btn-sm btn-primary" onclick="filterDangKy('all',this)">Tất cả</button>
                        <button class="btn btn-sm btn-outline-success" onclick="filterDangKy('DaDuyet',this)">Đã duyệt</button>
                        <button class="btn btn-sm btn-outline-info" onclick="filterDangKy('DangHoc',this)">Đang học</button>
                        <button class="btn btn-sm btn-outline-secondary" onclick="filterDangKy('HoanThanh',this)">Hoàn thành</button>
                        <button class="btn btn-sm btn-outline-warning" onclick="filterDangKy('ChoDuyet',this)">Chờ duyệt</button>
                        <button class="btn btn-sm btn-outline-danger" onclick="filterDangKy('HuyBo',this)">Hủy bỏ</button>
                    </div>
                    <span class="text-muted small" id="countLabel"></span>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Khóa học</th>
                                <th>Ngôn ngữ</th>
                                <th>Học phí</th>
                                <th>Ngày đăng ký</th>
                                <th>Trạng thái</th>
                                <th>Thanh toán</th>
                            </tr>
                        </thead>
                        <tbody id="dangKyTable"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
let allData = [];
let currentFilter = 'all';

async function loadLichSu() {
    try {
        const res = await apiCall('/api/dang-ky/cua-toi');
        if (!res.ok) { window.location.href = '/Auth/DangNhap'; return; }
        allData = await res.json();
        document.getElementById('loadingState').classList.add('d-none');
        if (!allData.length) {
            document.getElementById('emptyState').classList.remove('d-none');
        } else {
            document.getElementById('dangKyContainer').classList.remove('d-none');
            renderPendingBanner();
            renderTable('all');
        }
    } catch(e) {
        document.getElementById('loadingState').classList.add('d-none');
        document.getElementById('emptyState').classList.remove('d-none');
    }
}

function renderPendingBanner() {
    // Tìm đăng ký chờ thanh toán (ChoDuyet chưa chọn phương thức)
    const pendingPay = allData.filter(d => d.trangThai === 'ChoDuyet' && !d.phuongThucThanhToan);
    const waitConfirm = allData.filter(d => d.trangThai === 'ChoDuyet' && d.phuongThucThanhToan);
    const banner = document.getElementById('pendingPaymentBanner');

    if (pendingPay.length > 0) {
        banner.classList.remove('d-none');
        banner.innerHTML = `
            <div class="alert alert-warning border-0 shadow-sm d-flex align-items-center gap-3">
                <i class="bi bi-exclamation-triangle-fill text-warning fs-3 flex-shrink-0"></i>
                <div class="flex-grow-1">
                    <strong>Bạn có ${pendingPay.length} khóa học chờ thanh toán!</strong>
                    <div class="small text-muted mt-1">
                        ${pendingPay.map(d => `<a href="/HocVien/ThanhToan/${d.id}" class="btn btn-warning btn-sm me-2 mt-1">
                            <i class="bi bi-credit-card me-1"></i>${d.tenKhoaHoc} – Thanh toán ngay
                        </a>`).join('')}
                    </div>
                </div>
            </div>`;
    } else if (waitConfirm.length > 0) {
        banner.classList.remove('d-none');
        banner.innerHTML = `
            <div class="alert alert-info border-0 shadow-sm d-flex align-items-center gap-3">
                <i class="bi bi-hourglass-split text-info fs-3 flex-shrink-0"></i>
                <div>
                    <strong>Đang chờ xác nhận thanh toán (${waitConfirm.length} khóa học)</strong>
                    <div class="small text-muted">Admin sẽ xác nhận và kích hoạt khóa học cho bạn sớm nhất.</div>
                </div>
            </div>`;
    }
}

function filterDangKy(f, btn) {
    currentFilter = f;
    document.querySelectorAll('#filterBtns button').forEach(b => {
        b.className = b.className.replace(/btn-(?!outline)(?!sm)(\w+)/, 'btn-outline-$1');
    });
    btn.className = btn.className.replace('btn-outline-', 'btn-');
    renderTable(f);
}

function renderTable(f) {
    const filtered = f === 'all' ? allData : allData.filter(d => d.trangThai === f);
    document.getElementById('countLabel').textContent = `${filtered.length} khóa học`;

    const statusMap = {
        'DaDuyet':    '<span class="badge bg-success">✅ Đã duyệt</span>',
        'DangHoc':    '<span class="badge bg-primary">📚 Đang học</span>',
        'HoanThanh':  '<span class="badge bg-secondary">🎓 Hoàn thành</span>',
        'ChoDuyet':   '<span class="badge bg-warning text-dark">⏳ Chờ duyệt</span>',
        'HuyBo':      '<span class="badge bg-danger">❌ Hủy bỏ</span>'
    };

    const phuongThucLabel = { 'ChuyenKhoan': '🏦 Chuyển khoản', 'TienMat': '💵 Tiền mặt' };

    document.getElementById('dangKyTable').innerHTML = filtered.length === 0
        ? `<tr><td colspan="6" class="text-center text-muted py-4">Không có dữ liệu</td></tr>`
        : filtered.map(d => `
            <tr>
                <td>
                    <div class="fw-semibold">${d.tenKhoaHoc || '—'}</div>
                    <div class="text-muted small">${d.maKhoaHoc || ''}</div>
                </td>
                <td><span class="badge-lang bg-primary bg-opacity-10 text-primary">${d.ngonNgu || '—'}</span></td>
                <td class="fw-semibold text-success">${(d.hocPhi || 0).toLocaleString('vi-VN')}đ</td>
                <td class="text-muted small">${d.ngayDangKy ? new Date(d.ngayDangKy).toLocaleDateString('vi-VN') : '—'}</td>
                <td>${statusMap[d.trangThai] || d.trangThai}</td>
                <td>
                    ${d.trangThai === 'ChoDuyet' && !d.phuongThucThanhToan
                        ? `<a href="/HocVien/ThanhToan/${d.id}" class="btn btn-warning btn-sm fw-semibold">
                               <i class="bi bi-credit-card me-1"></i>Thanh toán
                           </a>`
                        : d.trangThai === 'ChoDuyet' && d.phuongThucThanhToan
                        ? `<a href="/HocVien/ThanhToan/${d.id}" class="btn btn-outline-secondary btn-sm">
                               <i class="bi bi-clock-history me-1"></i>Chờ xác nhận
                           </a>`
                        : d.trangThai === 'DangHoc'
                        ? `<span class="text-success small"><i class="bi bi-check-circle me-1"></i>${d.soTienDaThanhToan > 0 ? (d.soTienDaThanhToan).toLocaleString('vi-VN') + 'đ' : 'Đã thanh toán'}</span>`
                        : '—'}
                </td>
            </tr>`).join('');
}

document.addEventListener('DOMContentLoaded', loadLichSu);
</script>
