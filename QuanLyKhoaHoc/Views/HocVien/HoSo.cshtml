@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    Layout = "_Layout";
}

<div class="container py-4" style="max-width:860px">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="stat-icon bg-success bg-opacity-10"><i class="bi bi-person-circle text-success fs-4"></i></div>
        <div>
            <h4 class="mb-0 fw-bold">Hồ sơ cá nhân</h4>
            <p class="text-muted mb-0 small">Quản lý thông tin và bảo mật tài khoản</p>
        </div>
        <div class="ms-auto">
            <a href="/HocVien/Dashboard" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Dashboard
            </a>
        </div>
    </div>

    <!-- Loading -->
    <div id="loadingState" class="text-center py-5">
        <div class="spinner-border text-primary"></div>
        <p class="text-muted mt-2">Đang tải hồ sơ...</p>
    </div>

    <div id="mainContent" class="d-none">
        <div class="row g-4">
            <!-- Avatar & tóm tắt -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm text-center p-4">
                    <!-- Avatar with upload button -->
                    <div class="position-relative d-inline-block mx-auto mb-3" style="width:80px;height:80px">
                        <div id="profileAvatar" class="avatar-circle" style="width:80px;height:80px;font-size:2rem">?</div>
                        <button type="button" onclick="moUploadAvatarHV()" title="Đổi ảnh đại diện"
                            class="btn btn-sm btn-dark position-absolute bottom-0 end-0 rounded-circle p-0"
                            style="width:26px;height:26px;line-height:1">
                            <i class="bi bi-camera-fill" style="font-size:.75rem"></i>
                        </button>
                    </div>
                    <h5 class="fw-bold mb-0" id="profileName">—</h5>
                    <small class="text-muted" id="profileEmail">—</small>
                    <hr>
                    <div class="text-start small">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-person-badge text-primary"></i>
                            <span class="text-muted">Mã HV:</span>
                            <strong id="profileMaHV">—</strong>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-calendar-check text-success"></i>
                            <span class="text-muted">Ngày đăng ký:</span>
                            <strong id="profileNgayDK">—</strong>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-book-half text-warning"></i>
                            <span class="text-muted">Đang học:</span>
                            <strong id="profileSoKH">—</strong>
                            <span class="text-muted">khóa</span>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="badge bg-success px-3 py-2">🎓 Học viên EduCenter</span>
                    </div>
                </div>
            </div>

            <!-- Form chỉnh sửa -->
            <div class="col-md-8">
                <!-- Tab thông tin -->
                <ul class="nav nav-tabs mb-3" id="profileTabs">
                    <li class="nav-item">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabThongTin">
                            <i class="bi bi-person me-1"></i>Thông tin
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabBaoMat">
                            <i class="bi bi-shield-lock me-1"></i>Bảo mật
                        </button>
                    </li>
                </ul>

                <div class="tab-content">
                    <!-- Tab thông tin cá nhân -->
                    <div class="tab-pane fade show active" id="tabThongTin">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body p-4">
                                <form id="formThongTin">
                                    <div class="row g-3">
                                        <div class="col-sm-6">
                                            <label class="form-label fw-semibold">Họ và tên <span class="text-danger">*</span></label>
                                            <input type="text" class="form-control" id="inpHoTen" required maxlength="100">
                                        </div>
                                        <div class="col-sm-6">
                                            <label class="form-label fw-semibold">Email</label>
                                            <input type="email" class="form-control bg-light" id="inpEmail" readonly>
                                            <small class="text-muted">Email không thể thay đổi</small>
                                        </div>
                                        <div class="col-sm-6">
                                            <label class="form-label fw-semibold">Số điện thoại</label>
                                            <input type="tel" class="form-control" id="inpSoDT" maxlength="20" placeholder="0xxx xxx xxx">
                                        </div>
                                        <div class="col-sm-6">
                                            <label class="form-label fw-semibold">Ngày sinh</label>
                                            <input type="date" class="form-control" id="inpNgaySinh">
                                        </div>
                                        <div class="col-sm-6">
                                            <label class="form-label fw-semibold">Giới tính</label>
                                            <select class="form-select" id="inpGioiTinh">
                                                <option value="">-- Chọn --</option>
                                                <option value="Nam">Nam</option>
                                                <option value="Nữ">Nữ</option>
                                                <option value="Khác">Khác</option>
                                            </select>
                                        </div>
                                        <div class="col-sm-6">
                                            <label class="form-label fw-semibold">Trình độ hiện tại</label>
                                            <select class="form-select" id="inpTrinhDo">
                                                <option value="">-- Chọn --</option>
                                                <option value="Mới bắt đầu">Mới bắt đầu</option>
                                                <option value="Căn bản">Căn bản</option>
                                                <option value="Trung cấp">Trung cấp</option>
                                                <option value="Nâng cao">Nâng cao</option>
                                            </select>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label fw-semibold">Địa chỉ</label>
                                            <input type="text" class="form-control" id="inpDiaChi" maxlength="200" placeholder="Số nhà, đường, phường/xã, quận/huyện, tỉnh/thành phố">
                                        </div>
                                    </div>
                                    <div class="mt-4 d-flex gap-2">
                                        <button type="submit" class="btn btn-primary">
                                            <i class="bi bi-check2 me-1"></i>Lưu thay đổi
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary" onclick="loadProfile()">
                                            <i class="bi bi-arrow-counterclockwise me-1"></i>Hủy
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Tab bảo mật -->
                    <div class="tab-pane fade" id="tabBaoMat">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body p-4">
                                <h6 class="fw-bold mb-3"><i class="bi bi-key me-2 text-warning"></i>Đổi mật khẩu</h6>
                                <form id="formMatKhau">
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Mật khẩu hiện tại <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <input type="password" class="form-control" id="inpMKCu" required placeholder="Nhập mật khẩu hiện tại">
                                            <button class="btn btn-outline-secondary" type="button" onclick="togglePwd('inpMKCu',this)"><i class="bi bi-eye"></i></button>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Mật khẩu mới <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <input type="password" class="form-control" id="inpMKMoi" required minlength="6" placeholder="Tối thiểu 6 ký tự">
                                            <button class="btn btn-outline-secondary" type="button" onclick="togglePwd('inpMKMoi',this)"><i class="bi bi-eye"></i></button>
                                        </div>
                                    </div>
                                    <div class="mb-4">
                                        <label class="form-label fw-semibold">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <input type="password" class="form-control" id="inpMKXacNhan" required placeholder="Nhập lại mật khẩu mới">
                                            <button class="btn btn-outline-secondary" type="button" onclick="togglePwd('inpMKXacNhan',this)"><i class="bi bi-eye"></i></button>
                                        </div>
                                    </div>
                                    <button type="submit" class="btn btn-warning">
                                        <i class="bi bi-shield-check me-1"></i>Đổi mật khẩu
                                    </button>
                                </form>

                                <hr class="my-4">

                                <div class="alert alert-info d-flex gap-3 align-items-start">
                                    <i class="bi bi-info-circle-fill text-info mt-1 flex-shrink-0"></i>
                                    <div class="small">
                                        <strong>Lưu ý bảo mật:</strong><br>
                                        Sử dụng mật khẩu mạnh gồm chữ hoa, chữ thường, số và ký tự đặc biệt.
                                        Không chia sẻ mật khẩu với người khác.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let profileData = null;

document.addEventListener('DOMContentLoaded', async () => {
    if (!localStorage.getItem('jwt_token')) { window.location.href = '/Auth/DangNhap'; return; }
    await loadProfile();
});

async function loadProfile() {
    document.getElementById('loadingState').classList.remove('d-none');
    document.getElementById('mainContent').classList.add('d-none');

    const res = await apiCall('/api/hoc-vien/cua-toi');
    document.getElementById('loadingState').classList.add('d-none');
    if (!res.ok) { showToast('danger', 'Không thể tải hồ sơ'); return; }

    profileData = await res.json();
    renderProfile(profileData);
    document.getElementById('mainContent').classList.remove('d-none');
}

function renderProfile(d) {
    // Avatar
    const avatarEl = document.getElementById('profileAvatar');
    if (d.anhDaiDien) {
        avatarEl.innerHTML = `<img src="${d.anhDaiDien}" class="rounded-circle w-100 h-100 object-fit-cover" alt="avatar">`;
        avatarEl.className = 'rounded-circle overflow-hidden';
        avatarEl.style.cssText = 'width:80px;height:80px';
    } else {
        const w = (d.hoTen || 'HV').split(' ');
        const initials = w.length >= 2 ? (w[w.length-2][0] + w[w.length-1][0]).toUpperCase() : w[0][0].toUpperCase();
        avatarEl.textContent = initials;
        avatarEl.className = 'avatar-circle';
        avatarEl.style.cssText = 'width:80px;height:80px;font-size:2rem';
    }
    document.getElementById('profileName').textContent = d.hoTen || '—';
    document.getElementById('profileEmail').textContent = d.email || '—';
    document.getElementById('profileMaHV').textContent = d.maHocVien || '—';
    document.getElementById('profileNgayDK').textContent = d.ngayDangKy ? new Date(d.ngayDangKy).toLocaleDateString('vi-VN') : '—';
    document.getElementById('profileSoKH').textContent = d.soKhoaHocDangHoc ?? 0;

    // Form fields
    document.getElementById('inpHoTen').value = d.hoTen || '';
    document.getElementById('inpEmail').value = d.email || '';
    document.getElementById('inpSoDT').value = d.soDienThoai || '';
    document.getElementById('inpNgaySinh').value = d.ngaySinh ? d.ngaySinh.substring(0, 10) : '';
    document.getElementById('inpGioiTinh').value = d.gioiTinh || '';
    document.getElementById('inpTrinhDo').value = d.trinhDoHienTai || '';
    document.getElementById('inpDiaChi').value = d.diaChi || '';
}

document.getElementById('formThongTin').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = e.target.querySelector('[type=submit]');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Đang lưu...';

    const body = {
        hoTen: document.getElementById('inpHoTen').value.trim(),
        soDienThoai: document.getElementById('inpSoDT').value.trim(),
        ngaySinh: document.getElementById('inpNgaySinh').value || null,
        gioiTinh: document.getElementById('inpGioiTinh').value,
        trinhDoHienTai: document.getElementById('inpTrinhDo').value,
        diaChi: document.getElementById('inpDiaChi').value.trim()
    };

    const res = await apiCall('/api/hoc-vien/cua-toi', { method: 'PUT', body });
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-check2 me-1"></i>Lưu thay đổi';

    if (res.ok) {
        showToast('success', 'Cập nhật hồ sơ thành công!');
        // Update localStorage display name
        localStorage.setItem('ho_ten', body.hoTen);
        await loadProfile();
    } else {
        const err = await res.json().catch(() => ({}));
        showToast('danger', err.message || 'Cập nhật thất bại');
    }
});

document.getElementById('formMatKhau').addEventListener('submit', async (e) => {
    e.preventDefault();
    const mkMoi = document.getElementById('inpMKMoi').value;
    const mkXN = document.getElementById('inpMKXacNhan').value;
    if (mkMoi !== mkXN) { showToast('warning', 'Mật khẩu xác nhận không khớp'); return; }

    const btn = e.target.querySelector('[type=submit]');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Đang xử lý...';

    const res = await apiCall('/api/auth/doi-mat-khau', {
        method: 'POST',
        body: { matKhauCu: document.getElementById('inpMKCu').value, matKhauMoi: mkMoi }
    });
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-shield-check me-1"></i>Đổi mật khẩu';

    const d = await res.json().catch(() => ({}));
    if (res.ok) {
        showToast('success', 'Đổi mật khẩu thành công!');
        e.target.reset();
    } else {
        showToast('danger', d.message || 'Đổi mật khẩu thất bại');
    }
});

function togglePwd(id, btn) {
    const inp = document.getElementById(id);
    const isText = inp.type === 'text';
    inp.type = isText ? 'password' : 'text';
    btn.innerHTML = isText ? '<i class="bi bi-eye"></i>' : '<i class="bi bi-eye-slash"></i>';
}

// ─── Avatar upload ───────────────────────────────────────────
function moUploadAvatarHV() {
    document.getElementById('hvAvatarPreview').src = profileData?.anhDaiDien || '';
    document.getElementById('hvAvatarPreview').classList.toggle('d-none', !profileData?.anhDaiDien);
    document.getElementById('hvAvatarPlaceholder').classList.toggle('d-none', !!profileData?.anhDaiDien);
    document.getElementById('hvFileInput').value = '';
    new bootstrap.Modal(document.getElementById('modalUploadAvatarHV')).show();
}

function hvPreviewAvatar() {
    const file = document.getElementById('hvFileInput').files[0];
    if (!file) return;
    const allowed = ['image/jpeg','image/png','image/gif','image/webp'];
    if (!allowed.includes(file.type)) { showToast('warning','Chỉ hỗ trợ JPG, PNG, GIF, WEBP'); return; }
    if (file.size > 5*1024*1024) { showToast('warning','Ảnh không được vượt quá 5MB'); return; }
    const reader = new FileReader();
    reader.onload = e => {
        document.getElementById('hvAvatarPreview').src = e.target.result;
        document.getElementById('hvAvatarPreview').classList.remove('d-none');
        document.getElementById('hvAvatarPlaceholder').classList.add('d-none');
    };
    reader.readAsDataURL(file);
}

async function hvUploadAvatar() {
    const file = document.getElementById('hvFileInput').files[0];
    if (!file) { showToast('warning','Vui lòng chọn ảnh'); return; }
    const btn = document.getElementById('hvBtnUpload');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Đang tải...';

    const formData = new FormData();
    formData.append('file', file);
    try {
        const res = await fetch('/api/upload/avatar', {
            method: 'POST',
            headers: { 'Authorization': 'Bearer ' + localStorage.getItem('jwt_token') },
            body: formData
        });
        const d = await res.json().catch(() => ({}));
        if (res.ok) {
            showToast('success', 'Cập nhật ảnh đại diện thành công!');
            if (d.anhDaiDien) localStorage.setItem('anh_dai_dien', d.anhDaiDien);
            bootstrap.Modal.getInstance(document.getElementById('modalUploadAvatarHV')).hide();
            await loadProfile();
        } else {
            showToast('danger', d.message || 'Tải ảnh thất bại');
        }
    } catch { showToast('danger','Lỗi kết nối'); }
    finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-cloud-upload me-1"></i>Tải lên';
    }
}
</script>

<!-- Modal upload avatar -->
<div class="modal fade" id="modalUploadAvatarHV" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title fw-bold"><i class="bi bi-camera me-2"></i>Đổi ảnh đại diện</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <div id="hvAvatarPlaceholder" class="avatar-circle mx-auto mb-3" style="width:80px;height:80px;font-size:2rem">?</div>
                <img id="hvAvatarPreview" src="" class="rounded-circle d-none mb-3" style="width:80px;height:80px;object-fit:cover" alt="preview">
                <div class="mb-3">
                    <input type="file" id="hvFileInput" class="form-control form-control-sm" accept="image/jpeg,image/png,image/gif,image/webp" onchange="hvPreviewAvatar()">
                    <small class="text-muted">JPG, PNG, GIF, WEBP – tối đa 5MB</small>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Hủy</button>
                <button id="hvBtnUpload" class="btn btn-primary btn-sm" onclick="hvUploadAvatar()">
                    <i class="bi bi-cloud-upload me-1"></i>Tải lên
                </button>
            </div>
        </div>
    </div>
</div>
}
