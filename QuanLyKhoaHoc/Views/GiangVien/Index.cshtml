@using QuanLyKhoaHoc.Models
@model List<GiangVien>
@{
    ViewData["Title"] = "Đội ngũ giảng viên";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold"><i class="bi bi-people-fill text-primary me-2"></i>Đội Ngũ Giảng Viên</h2>
        <p class="text-muted">Những chuyên gia ngôn ngữ tận tâm, giàu kinh nghiệm</p>
    </div>

    <div class="row g-4">
        @foreach (var gv in Model)
        {
            var soLop = gv.DanhSachPhanCong.Count(p => p.DangHoatDong);
            var initials = string.Join("", gv.NguoiDung.HoTen.Split(' ').TakeLast(2).Select(w => w[0]));
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100 gv-card">
                    <div class="card-body text-center p-4">
                        <div class="gv-avatar mx-auto mb-3">
                            <span class="fw-bold fs-4 text-white">@initials</span>
                        </div>
                        <h5 class="fw-bold mb-1">@gv.NguoiDung.HoTen</h5>
                        <div class="text-primary small fw-semibold mb-2">@gv.ChuyenNganh</div>
                        <div class="d-flex justify-content-center gap-3 mb-3">
                            <span class="badge bg-light text-dark border">
                                <i class="bi bi-award me-1 text-warning"></i>@gv.BangCap
                            </span>
                            <span class="badge bg-light text-dark border">
                                <i class="bi bi-clock-history me-1 text-info"></i>@gv.NamKinhNghiem năm
                            </span>
                        </div>
                        @if (!string.IsNullOrEmpty(gv.GioiThieu))
                        {
                            <p class="text-muted small mb-3">@gv.GioiThieu</p>
                        }
                        <div class="d-flex justify-content-center gap-3 text-muted small">
                            <span><i class="bi bi-book me-1 text-primary"></i>@soLop lớp</span>
                            <span><i class="bi bi-envelope me-1 text-primary"></i>@gv.NguoiDung.Email</span>
                        </div>
                    </div>
                    <div class="card-footer border-0 bg-transparent text-center pb-3">
                        @foreach (var pc in gv.DanhSachPhanCong.Where(p => p.DangHoatDong).Take(3))
                        {
                            <span class="badge bg-primary me-1 mb-1" style="font-size:0.7rem">@pc.KhoaHoc?.NgonNgu</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-people fs-1"></i>
            <p class="mt-3">Chưa có thông tin giảng viên</p>
        </div>
    }
</div>
