@{
    ViewData["Title"] = "Lịch học";
}

<div class="container-fluid py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h4 class="fw-bold mb-1"><i class="bi bi-calendar3 text-primary me-2"></i>Lịch học</h4>
            <p class="text-muted small mb-0" id="subtitleLich">Đang tải lịch...</p>
        </div>
        <div class="d-flex gap-2 flex-wrap align-items-center">
            <!-- Week navigation (only shown in timetable view) -->
            <div class="btn-group" id="weekNavGroup">
                <button class="btn btn-outline-secondary btn-sm" onclick="changeWeek(-1)" title="Tuần trước">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <button class="btn btn-outline-secondary btn-sm" id="btnTodayWeek" onclick="changeWeek(0)">
                    Hôm nay
                </button>
                <button class="btn btn-outline-secondary btn-sm" onclick="changeWeek(1)" title="Tuần sau">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
            <!-- View toggle -->
            <div class="btn-group" id="viewToggle">
                <button class="btn btn-outline-primary btn-sm active" id="btnTimetable" onclick="switchView('timetable')">
                    <i class="bi bi-table me-1"></i>Thời khóa biểu
                </button>
                <button class="btn btn-outline-primary btn-sm" id="btnList" onclick="switchView('list')">
                    <i class="bi bi-list-ul me-1"></i>Danh sách
                </button>
            </div>
            <!-- List filters (only shown in list view) -->
            <div class="btn-group" id="listFilterGroup" style="display:none!important">
                <button class="btn btn-primary btn-sm filter-btn" onclick="setFilter('all',this)">Tất cả</button>
                <button class="btn btn-outline-primary btn-sm filter-btn" onclick="setFilter('today',this)">📅 Hôm nay</button>
                <button class="btn btn-outline-primary btn-sm filter-btn" onclick="setFilter('week',this)">📆 Tuần này</button>
            </div>
            <button class="btn btn-outline-secondary btn-sm" onclick="loadMyLich()">
                <i class="bi bi-arrow-clockwise me-1"></i>Làm mới
            </button>
            <button class="btn btn-outline-success btn-sm" onclick="taiLichHoc()" title="Tải lịch học">
                <i class="bi bi-download me-1"></i>Tải lịch
            </button>
        </div>
    </div>

    <!-- Legend màu sắc ngôn ngữ -->
    <div class="d-flex flex-wrap gap-3 mb-4" id="legend">
        <span class="badge-lang" style="--c:#0d6efd"><span class="dot" style="background:#0d6efd"></span>Tiếng Anh</span>
        <span class="badge-lang" style="--c:#dc3545"><span class="dot" style="background:#dc3545"></span>Tiếng Nhật</span>
        <span class="badge-lang" style="--c:#fd7e14"><span class="dot" style="background:#fd7e14"></span>Tiếng Hàn</span>
        <span class="badge-lang" style="--c:#198754"><span class="dot" style="background:#198754"></span>Tiếng Trung</span>
        <span class="badge-lang" style="--c:#6f42c1"><span class="dot" style="background:#6f42c1"></span>Tiếng Pháp</span>
    </div>

    <!-- Loading -->
    <div id="loadingLich" class="text-center py-5">
        <div class="spinner-border text-primary mb-3" style="width:3rem;height:3rem"></div>
        <p class="text-muted">Đang tải lịch học...</p>
    </div>

    <!-- Timetable view -->
    <div id="viewTimetable" style="display:none">
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered timetable mb-0" id="timetableTable">
                        <thead id="timetableHead">
                            <tr class="bg-primary text-white">
                                <th class="time-col text-center py-3">Giờ</th>
                                <th class="text-center py-3" id="th-1">Thứ 2</th>
                                <th class="text-center py-3" id="th-2">Thứ 3</th>
                                <th class="text-center py-3" id="th-3">Thứ 4</th>
                                <th class="text-center py-3" id="th-4">Thứ 5</th>
                                <th class="text-center py-3" id="th-5">Thứ 6</th>
                                <th class="text-center py-3" id="th-6">Thứ 7</th>
                                <th class="text-center py-3" id="th-0">CN</th>
                            </tr>
                        </thead>
                        <tbody id="timetableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- List view -->
    <div id="viewList" style="display:none">
        <div class="row g-3" id="listContainer"></div>
    </div>

    <!-- Empty state -->
    <div id="emptyState" style="display:none" class="text-center py-5">
        <i class="bi bi-calendar-x text-muted" style="font-size:4rem"></i>
        <h5 class="mt-3 text-muted">Không có lịch học nào</h5>
        <p class="text-muted small">Đăng ký khóa học để xem lịch học của bạn</p>
        <a href="/KhoaHoc" class="btn btn-primary mt-2">
            <i class="bi bi-book me-2"></i>Xem khóa học
        </a>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script src="~/js/calendar.js" asp-append-version="true"></script>
<script>
document.addEventListener('DOMContentLoaded', () => {
    if (!localStorage.getItem('jwt_token')) {
        window.location.href = '/Auth/DangNhap?returnUrl=' + encodeURIComponent(window.location.pathname);
        return;
    }
    loadMyLich();
});

// Override switchView to also toggle filter group and week nav
const _origSwitchView = switchView;
window.switchView = function(view) {
    _origSwitchView(view);
    const fg = document.getElementById('listFilterGroup');
    const wn = document.getElementById('weekNavGroup');
    if (fg) fg.style.setProperty('display', view === 'list' ? 'flex' : 'none', 'important');
    if (wn) wn.style.display = view === 'timetable' ? '' : 'none';
};
</script>
<style>
@@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.5} }
@@keyframes livePulse { 0%,100%{box-shadow:0 0 0 0 rgba(220,53,69,.4)} 50%{box-shadow:0 0 0 6px rgba(220,53,69,0)} }
.lich-cell-live { animation: livePulse 1.5s infinite; }
.current-time-line { position:absolute; left:0; right:0; height:2px; background:#dc3545; z-index:10; pointer-events:none; }
.current-time-line::before { content:''; position:absolute; left:-4px; top:-4px; width:10px; height:10px; border-radius:50%; background:#dc3545; }
</style>
}
