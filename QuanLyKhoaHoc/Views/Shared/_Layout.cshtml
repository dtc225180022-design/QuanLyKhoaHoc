<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduCenter</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">
                <i class="bi bi-mortarboard-fill me-2"></i>EduCenter
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">
                            <i class="bi bi-house me-1"></i>Trang chủ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/KhoaHoc">
                            <i class="bi bi-book me-1"></i>Khóa học
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/GiangVien">
                            <i class="bi bi-person-badge me-1"></i>Giảng viên
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/LichHoc">
                            <i class="bi bi-calendar3 me-1"></i>Lịch học
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/TinTuc">
                            <i class="bi bi-newspaper me-1"></i>Tin tức
                        </a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto align-items-lg-center gap-1">
                    <!-- Admin only -->
                    <li class="nav-item d-none" id="navAdmin">
                        <a class="nav-link" href="/Admin">
                            <i class="bi bi-speedometer2 me-1"></i>Quản trị
                        </a>
                    </li>
                    <!-- GiangVien only -->
                    <li class="nav-item d-none" id="navGiangVien">
                        <a class="nav-link" href="/GiangVien/Dashboard">
                            <i class="bi bi-easel me-1"></i>Lớp dạy
                        </a>
                    </li>
                    <!-- HocVien only -->
                    <li class="nav-item dropdown d-none" id="navHocVien">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-mortarboard me-1"></i>Học tập
                        </a>
                        <ul class="dropdown-menu shadow">
                            <li><a class="dropdown-item" href="/HocVien/Dashboard"><i class="bi bi-grid me-2 text-primary"></i>Dashboard</a></li>
                            <li><a class="dropdown-item fw-semibold" href="/HocVien/LichSuDangKy"><i class="bi bi-book-half me-2 text-success"></i>Khóa học của tôi</a></li>
                            <li><a class="dropdown-item" href="/LichHoc"><i class="bi bi-calendar3 me-2 text-info"></i>Lịch học</a></li>
                            <li><a class="dropdown-item" href="/diem-cua-toi"><i class="bi bi-award me-2 text-warning"></i>Kết quả học tập</a></li>
                        </ul>
                    </li>
                    <!-- Logged in user dropdown -->
                    <li class="nav-item dropdown d-none" id="navLoggedIn">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-1" href="#" data-bs-toggle="dropdown">
                            <span class="avatar-circle" id="navAvatar">?</span>
                            <span id="navUserName" class="d-none d-lg-inline">Tài khoản</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li class="px-3 py-2 border-bottom">
                                <div class="fw-semibold" id="navFullName"></div>
                                <small class="text-muted" id="navRole"></small>
                            </li>
                            <li><a class="dropdown-item" href="/HocVien/Dashboard" id="navMenuDashboard"><i class="bi bi-grid me-2 text-primary"></i>Dashboard</a></li>
                            <li><a class="dropdown-item" href="/ho-so" id="linkHoSoHV"><i class="bi bi-person-circle me-2 text-success"></i>Hồ sơ cá nhân</a></li>
                            <li><a class="dropdown-item d-none" href="/ho-so-giang-vien" id="linkHoSoGV"><i class="bi bi-person-badge me-2 text-success"></i>Hồ sơ giảng viên</a></li>
                            <li id="navMenuKhoaHoc"><a class="dropdown-item fw-semibold" href="/HocVien/LichSuDangKy"><i class="bi bi-book-half me-2 text-success"></i>Khóa học của tôi</a></li>
                            <li id="navMenuLichHoc"><a class="dropdown-item" href="/LichHoc"><i class="bi bi-calendar3 me-2 text-info"></i>Lịch học của tôi</a></li>
                            <li id="navMenuKetQua"><a class="dropdown-item" href="/diem-cua-toi"><i class="bi bi-award me-2 text-warning"></i>Kết quả học tập</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="#" id="btnLogout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                        </ul>
                    </li>
                    <!-- Logged out -->
                    <li class="nav-item" id="navLoggedOut">
                        <a class="btn btn-outline-light btn-sm" href="/Auth/DangNhap">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập
                        </a>
                    </li>
                    <li class="nav-item d-none" id="navRegisterBtn">
                        <a class="btn btn-warning btn-sm fw-semibold" href="/Auth/DangKy">Đăng ký</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible m-0 rounded-0 text-center py-2" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible m-0 rounded-0 text-center py-2" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <main class="flex-grow-1">
        @RenderBody()
    </main>

    <footer class="bg-dark text-light py-5 mt-auto">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-mortarboard-fill text-warning me-2"></i>EduCenter</h5>
                    <p class="text-muted small">Trung tâm ngoại ngữ hàng đầu Việt Nam, cung cấp các khóa học chất lượng cao với đội ngũ giảng viên chuyên nghiệp và phương pháp giảng dạy hiện đại.</p>
                    <div class="d-flex gap-3 mt-3">
                        <a href="#" class="text-muted fs-5"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-muted fs-5"><i class="bi bi-youtube"></i></a>
                        <a href="#" class="text-muted fs-5"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>
                <div class="col-md-4">
                    <h6 class="fw-bold mb-3 text-white">Liên kết nhanh</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-1"><a href="/" class="text-muted text-decoration-none hover-white"><i class="bi bi-chevron-right me-1 text-warning"></i>Trang chủ</a></li>
                        <li class="mb-1"><a href="/KhoaHoc" class="text-muted text-decoration-none"><i class="bi bi-chevron-right me-1 text-warning"></i>Khóa học</a></li>
                        <li class="mb-1"><a href="/GiangVien" class="text-muted text-decoration-none"><i class="bi bi-chevron-right me-1 text-warning"></i>Giảng viên</a></li>
                        <li class="mb-1"><a href="/LichHoc" class="text-muted text-decoration-none"><i class="bi bi-chevron-right me-1 text-warning"></i>Lịch học</a></li>
                        <li class="mb-1"><a href="/Auth/DangKy" class="text-muted text-decoration-none"><i class="bi bi-chevron-right me-1 text-warning"></i>Đăng ký học</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="fw-bold mb-3 text-white">Liên hệ</h6>
                    <div class="d-flex align-items-start mb-2">
                        <i class="bi bi-geo-alt-fill text-warning me-2 mt-1 flex-shrink-0"></i>
                        <span class="text-muted small">123 Đường Láng, Đống Đa, Hà Nội</span>
                    </div>
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-telephone-fill text-warning me-2 flex-shrink-0"></i>
                        <a href="tel:19006868" class="text-muted small text-decoration-none">1900 6868</a>
                    </div>
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-envelope-fill text-warning me-2 flex-shrink-0"></i>
                        <a href="mailto:contact@educenter.vn" class="text-muted small text-decoration-none">contact@educenter.vn</a>
                    </div>
                    <div class="d-flex align-items-center">
                        <i class="bi bi-clock-fill text-warning me-2 flex-shrink-0"></i>
                        <span class="text-muted small">Thứ 2 – Chủ nhật: 7:00 – 21:00</span>
                    </div>
                </div>
            </div>
            <hr class="border-secondary mt-4">
            <p class="text-center text-muted small mb-0">
                &copy; 2026 EduCenter – Trung Tâm Ngoại Ngữ. All rights reserved.
                <span class="mx-2">|</span>
                <a href="/Auth/DangNhap" class="text-muted text-decoration-none">Đăng nhập</a>
            </p>
        </div>
    </footer>

    <!-- Toast container -->
    <div id="toastContainer" aria-live="polite"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/auth.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
