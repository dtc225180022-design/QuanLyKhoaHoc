@using QuanLyKhoaHoc.Models
@model List<KhoaHoc>
@{
    ViewData["Title"] = "Khóa học";
}

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h4 class="fw-bold mb-1"><i class="bi bi-book text-primary me-2"></i>Danh sách khóa học</h4>
            <p class="text-muted small mb-0">Tìm thấy <strong>@Model.Count</strong> khóa học</p>
        </div>
    </div>

    <!-- Bộ lọc -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" action="/KhoaHoc" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Tìm kiếm</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" name="search" class="form-control" value="@ViewBag.Search" placeholder="Tên hoặc mã khóa học..." />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Ngôn ngữ</label>
                    <select name="ngonNgu" class="form-select">
                        <option value="">Tất cả</option>
                        @foreach (var n in (ViewBag.DanhSachNgonNgu as List<string> ?? new()))
                        {
                            <option value="@n" selected="@(ViewBag.NgonNgu == n)">@n</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Trình độ</label>
                    <select name="trinhDo" class="form-select">
                        <option value="">Tất cả</option>
                        @foreach (var t in (ViewBag.DanhSachTrinhDo as List<string> ?? new()))
                        {
                            <option value="@t" selected="@(ViewBag.TrinhDo == t)">@t</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-fill">
                        <i class="bi bi-funnel me-1"></i>Lọc
                    </button>
                    <a href="/KhoaHoc" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Grid khóa học -->
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-search fs-1"></i>
            <h5 class="mt-3">Không tìm thấy khóa học phù hợp</h5>
            <a href="/KhoaHoc" class="btn btn-primary mt-3">Xem tất cả khóa học</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var kh in Model)
            {
                var soHv = kh.DanhSachDangKy.Count(d => d.TrangThai != TrangThaiDangKy.HuyBo);
                var phanTram = kh.SoLuongToiDa > 0 ? (soHv * 100 / kh.SoLuongToiDa) : 0;
                var gv = kh.DanhSachPhanCong.FirstOrDefault(p => p.DangHoatDong)?.GiangVien?.NguoiDung?.HoTen ?? "Chưa phân công";
                var trangThaiClass = kh.TrangThai switch {
                    TrangThaiKhoaHoc.MoChuaHoc => "success",
                    TrangThaiKhoaHoc.DangHoc => "primary",
                    TrangThaiKhoaHoc.DaKetThuc => "secondary",
                    _ => "danger" };
                var ngonNguColor = kh.NgonNgu switch {
                    "Tiếng Anh" => "#0d6efd", "Tiếng Nhật" => "#dc3545",
                    "Tiếng Hàn" => "#fd7e14", "Tiếng Trung" => "#198754",
                    "Tiếng Pháp" => "#6f42c1", _ => "#6c757d" };

                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 course-card" style="border-top:3px solid @ngonNguColor!important">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="badge text-white" style="background:@ngonNguColor">@kh.NgonNgu</span>
                                <div class="d-flex gap-1">
                                    <span class="badge bg-light text-dark border" style="font-size:.7rem">@kh.TrinhDo</span>
                                    <span class="badge bg-@trangThaiClass" style="font-size:.7rem">
                                        @(kh.TrangThai == TrangThaiKhoaHoc.MoChuaHoc ? "Mở ĐK" : kh.TrangThai.ToString())
                                    </span>
                                </div>
                            </div>
                            <h6 class="fw-bold mb-1">@kh.TenKhoaHoc</h6>
                            <p class="text-muted small mb-2">@(kh.MoTa.Length > 90 ? kh.MoTa[..90] + "…" : kh.MoTa)</p>

                            <div class="text-muted small mb-1">
                                <i class="bi bi-person-badge me-1 text-primary"></i>@gv
                            </div>
                            <div class="text-muted small mb-1">
                                <i class="bi bi-calendar-event me-1 text-primary"></i>@kh.NgayBatDau.ToString("dd/MM/yyyy") – @kh.NgayKetThuc.ToString("dd/MM/yyyy")
                            </div>
                            <div class="text-muted small mb-3">
                                <i class="bi bi-clock me-1 text-primary"></i>@kh.SoBuoiHoc buổi × @kh.ThoiLuongMoiBuoi phút
                            </div>

                            <div class="mb-2">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span>Sĩ số: <strong>@soHv/@kh.SoLuongToiDa</strong></span>
                                    <span class="@(phanTram >= 80 ? "text-danger" : "text-success")">@phanTram%</span>
                                </div>
                                <div class="progress" style="height:5px">
                                    <div class="progress-bar @(phanTram >= 80 ? "bg-danger" : "bg-success")" style="width:@phanTram%"></div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer border-0 bg-transparent d-flex justify-content-between align-items-center pt-0 pb-3 px-3">
                            <div>
                                <span class="fw-bold text-primary fs-6">@kh.HocPhi.ToString("N0")₫</span>
                                <span class="text-muted small ms-1">/ khóa</span>
                            </div>
                            <div class="d-flex gap-1">
                                <a href="/KhoaHoc/ChiTiet/@kh.Id" class="btn btn-outline-secondary btn-sm" title="Chi tiết">
                                    <i class="bi bi-info-circle"></i>
                                </a>
                                @if (kh.TrangThai == TrangThaiKhoaHoc.MoChuaHoc)
                                {
                                    <button class="btn btn-primary btn-sm" onclick="dangKyKhoaHoc(@kh.Id)">
                                        <i class="bi bi-plus-circle me-1"></i>Đăng ký
                                    </button>
                                }
                                else
                                {
                                    <span class="badge bg-secondary align-self-center">Không mở ĐK</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<script>
async function dangKyKhoaHoc(id) {
    const token = localStorage.getItem('jwt_token');
    if (!token) { window.location.href = '/Auth/DangNhap'; return; }
    if (!confirm('Bạn muốn đăng ký khóa học này?')) return;
    const res = await apiCall('/api/hoc-vien/dang-ky-khoa-hoc', {
        method: 'POST',
        body: { khoaHocId: id, ghiChu: '' }
    });
    const d = await res.json();
    showToast(res.ok ? 'success' : 'danger', d.message);
    if (res.ok) setTimeout(() => location.reload(), 1500);
}
</script>
}
