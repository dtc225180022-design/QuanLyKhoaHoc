@using QuanLyKhoaHoc.Models
@model KhoaHoc
@{
    ViewData["Title"] = Model.TenKhoaHoc;
    var soHv = Model.DanhSachDangKy.Count(d => d.TrangThai != TrangThaiDangKy.HuyBo);
    var phanTram = Model.SoLuongToiDa > 0 ? (soHv * 100 / Model.SoLuongToiDa) : 0;
    var gv = Model.DanhSachPhanCong.FirstOrDefault(p => p.DangHoatDong)?.GiangVien?.NguoiDung?.HoTen ?? "Chưa phân công";
    var ngonNguColor = Model.NgonNgu switch {
        "Tiếng Anh" => "#0d6efd", "Tiếng Nhật" => "#dc3545",
        "Tiếng Hàn" => "#fd7e14", "Tiếng Trung" => "#198754",
        "Tiếng Pháp" => "#6f42c1", _ => "#6c757d" };
    var trangThaiClass = Model.TrangThai switch {
        TrangThaiKhoaHoc.MoChuaHoc => "success",
        TrangThaiKhoaHoc.DangHoc => "primary",
        TrangThaiKhoaHoc.DaKetThuc => "secondary",
        _ => "danger" };
    var trangThaiLabel = Model.TrangThai switch {
        TrangThaiKhoaHoc.MoChuaHoc => "Mở đăng ký",
        TrangThaiKhoaHoc.DangHoc => "Đang học",
        TrangThaiKhoaHoc.DaKetThuc => "Đã kết thúc",
        _ => "Hủy bỏ" };
    var thuNames = new Dictionary<DayOfWeek,string> {
        {DayOfWeek.Monday,"Thứ 2"}, {DayOfWeek.Tuesday,"Thứ 3"}, {DayOfWeek.Wednesday,"Thứ 4"},
        {DayOfWeek.Thursday,"Thứ 5"}, {DayOfWeek.Friday,"Thứ 6"}, {DayOfWeek.Saturday,"Thứ 7"},
        {DayOfWeek.Sunday,"CN"} };
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="/KhoaHoc">Khóa học</a></li>
            <li class="breadcrumb-item active">@Model.TenKhoaHoc</li>
        </ol>
    </nav>

    <div class="row g-4">
        <!-- Main content -->
        <div class="col-lg-8">
            <!-- Course header -->
            <div class="card border-0 shadow-sm mb-4" style="border-top:4px solid @ngonNguColor!important">
                <div class="card-body p-4">
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge text-white px-3 py-2" style="background:@ngonNguColor">@Model.NgonNgu</span>
                        <span class="badge bg-light text-dark border px-3 py-2">@Model.TrinhDo</span>
                        <span class="badge bg-@trangThaiClass px-3 py-2">@trangThaiLabel</span>
                    </div>
                    <h3 class="fw-bold mb-3">@Model.TenKhoaHoc</h3>
                    <p class="text-muted">@Model.MoTa</p>
                    <div class="row g-3 mt-2">
                        <div class="col-6 col-md-3 text-center">
                            <div class="fw-bold text-primary fs-4">@Model.SoBuoiHoc</div>
                            <div class="text-muted small">Buổi học</div>
                        </div>
                        <div class="col-6 col-md-3 text-center">
                            <div class="fw-bold text-success fs-4">@Model.ThoiLuongMoiBuoi'</div>
                            <div class="text-muted small">Phút/buổi</div>
                        </div>
                        <div class="col-6 col-md-3 text-center">
                            <div class="fw-bold text-warning fs-4">@soHv/@Model.SoLuongToiDa</div>
                            <div class="text-muted small">Sĩ số</div>
                        </div>
                        <div class="col-6 col-md-3 text-center">
                            <div class="fw-bold text-danger fs-4">@phanTram%</div>
                            <div class="text-muted small">Đã điền</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tabs -->
            <ul class="nav nav-tabs mb-3" id="chiTietTabs">
                <li class="nav-item">
                    <a class="nav-link active" data-bs-toggle="tab" href="#tabThongTin">
                        <i class="bi bi-info-circle me-1"></i>Thông tin
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#tabLichHoc">
                        <i class="bi bi-calendar3 me-1"></i>Lịch học
                    </a>
                </li>
                <li class="nav-item" id="tabHocVienLi" style="display:none">
                    <a class="nav-link" data-bs-toggle="tab" href="#tabHocVienList" onclick="loadHocVienList()">
                        <i class="bi bi-people me-1"></i>Danh sách học viên <span class="badge bg-primary ms-1" id="hvCount">0</span>
                    </a>
                </li>
            </ul>

            <div class="tab-content">
                <!-- Tab thông tin -->
                <div class="tab-pane fade show active" id="tabThongTin">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-4">
                            <h6 class="fw-bold mb-3"><i class="bi bi-info-circle text-primary me-2"></i>Chi tiết khóa học</h6>
                            <dl class="row mb-0">
                                <dt class="col-5 col-md-4 text-muted small fw-normal">Mã khóa học</dt>
                                <dd class="col-7 col-md-8 fw-semibold">@Model.MaKhoaHoc</dd>

                                <dt class="col-5 col-md-4 text-muted small fw-normal">Ngôn ngữ</dt>
                                <dd class="col-7 col-md-8">
                                    <span class="badge text-white" style="background:@ngonNguColor">@Model.NgonNgu</span>
                                </dd>

                                <dt class="col-5 col-md-4 text-muted small fw-normal">Trình độ</dt>
                                <dd class="col-7 col-md-8">@Model.TrinhDo</dd>

                                <dt class="col-5 col-md-4 text-muted small fw-normal">Giảng viên</dt>
                                <dd class="col-7 col-md-8 fw-semibold">@gv</dd>

                                <dt class="col-5 col-md-4 text-muted small fw-normal">Ngày bắt đầu</dt>
                                <dd class="col-7 col-md-8">@Model.NgayBatDau.ToString("dd/MM/yyyy")</dd>

                                <dt class="col-5 col-md-4 text-muted small fw-normal">Ngày kết thúc</dt>
                                <dd class="col-7 col-md-8">@Model.NgayKetThuc.ToString("dd/MM/yyyy")</dd>

                                <dt class="col-5 col-md-4 text-muted small fw-normal">Học phí</dt>
                                <dd class="col-7 col-md-8 fw-bold text-primary fs-5">@Model.HocPhi.ToString("N0")₫</dd>
                            </dl>
                        </div>
                    </div>
                </div>

                <!-- Tab lịch học -->
                <div class="tab-pane fade" id="tabLichHoc">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-4">
                            <h6 class="fw-bold mb-3"><i class="bi bi-calendar3 text-primary me-2"></i>Lịch học cố định</h6>
                            @if (!Model.DanhSachLichHoc.Any())
                            {
                                <p class="text-muted">Chưa có lịch học</p>
                            }
                            else
                            {
                                <div class="row g-3">
                                    @foreach (var l in Model.DanhSachLichHoc.OrderBy(l => l.ThuTrongTuan))
                                    {
                                        var thuTen = thuNames.GetValueOrDefault(l.ThuTrongTuan, l.ThuTrongTuan.ToString());
                                        <div class="col-md-6">
                                            <div class="d-flex align-items-center gap-3 p-3 rounded bg-light">
                                                <div class="text-center" style="min-width:60px">
                                                    <div class="fw-bold text-primary">@thuTen</div>
                                                </div>
                                                <div>
                                                    <div class="fw-semibold"><i class="bi bi-clock me-1 text-primary"></i>@l.GioBatDau.ToString(@"hh\:mm") – @l.GioKetThuc.ToString(@"hh\:mm")</div>
                                                    <div class="text-muted small"><i class="bi bi-door-open me-1"></i>@l.PhongHoc</div>
                                                    <div class="text-muted small"><i class="bi bi-display me-1"></i>@l.HinhThuc</div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Tab danh sách học viên -->
                <div class="tab-pane fade" id="tabHocVienList">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-3">
                            <div id="hvListBody">
                                <div class="text-center py-4"><div class="spinner-border text-primary spinner-border-sm"></div><p class="text-muted mt-2 small">Đang tải...</p></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Registration card -->
            <div class="card border-0 shadow sticky-top" style="top:80px">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="fs-3 fw-bold text-primary">@Model.HocPhi.ToString("N0")₫</span>
                        <span class="text-muted small">/ khóa</span>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between small mb-1">
                            <span>Sĩ số: <strong>@soHv/@Model.SoLuongToiDa</strong></span>
                            <span class="@(phanTram >= 80 ? "text-danger" : "text-success")">@phanTram%</span>
                        </div>
                        <div class="progress" style="height:8px">
                            <div class="progress-bar @(phanTram >= 80 ? "bg-danger" : "bg-success")" style="width:@phanTram%"></div>
                        </div>
                        @if (phanTram >= 90)
                        {
                            <p class="text-danger small mt-1 mb-0"><i class="bi bi-exclamation-triangle me-1"></i>Gần đầy lớp!</p>
                        }
                    </div>

                    @if (Model.TrangThai == TrangThaiKhoaHoc.MoChuaHoc)
                    {
                        <button class="btn btn-primary w-100 fw-semibold mb-2" onclick="dangKyKhoaHoc(@Model.Id)">
                            <i class="bi bi-plus-circle me-2"></i>Đăng ký ngay
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-secondary w-100 fw-semibold mb-2" disabled>
                            @trangThaiLabel
                        </button>
                    }
                    <a href="/KhoaHoc" class="btn btn-outline-secondary w-100 btn-sm">
                        <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách
                    </a>

                    <hr class="my-3">
                    <div class="text-muted small">
                        <div class="d-flex justify-content-between mb-2">
                            <span><i class="bi bi-calendar-event me-2"></i>Bắt đầu</span>
                            <strong>@Model.NgayBatDau.ToString("dd/MM/yyyy")</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span><i class="bi bi-calendar-check me-2"></i>Kết thúc</span>
                            <strong>@Model.NgayKetThuc.ToString("dd/MM/yyyy")</strong>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span><i class="bi bi-person-badge me-2"></i>Giảng viên</span>
                            <strong>@gv</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const khoaHocId = @Model.Id;
let hvLoaded = false;

// Show/hide student tab based on role
document.addEventListener('DOMContentLoaded', () => {
    const vaiTro = localStorage.getItem('vai_tro');
    if (vaiTro === 'Admin' || vaiTro === 'GiangVien') {
        document.getElementById('tabHocVienLi').style.display = '';
    }
});

async function loadHocVienList() {
    if (hvLoaded) return;
    hvLoaded = true;
    try {
        const res = await apiCall(`/api/khoa-hoc/${khoaHocId}/hoc-vien`);
        const data = await res.json();
        const count = Array.isArray(data) ? data.length : 0;
        document.getElementById('hvCount').textContent = count;

        if (!count) {
            document.getElementById('hvListBody').innerHTML = `
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-people fs-1 d-block mb-2"></i>
                    <p>Chưa có học viên đăng ký</p>
                </div>`;
            return;
        }

        const statusColors = { 'ChoDuyet':'warning','DaDuyet':'info','DangHoc':'primary','HoanThanh':'success','HuyBo':'danger' };
        const statusLabels = { 'ChoDuyet':'Chờ duyệt','DaDuyet':'Đã duyệt','DangHoc':'Đang học','HoanThanh':'Hoàn thành','HuyBo':'Hủy' };

        document.getElementById('hvListBody').innerHTML = `
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-people text-primary me-2"></i>Danh sách học viên (${count})</h6>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle table-sm">
                    <thead class="table-light">
                        <tr><th>#</th><th>Ảnh</th><th>Họ tên</th><th>Mã HV</th><th>Email</th><th>SĐT</th><th>Trạng thái</th></tr>
                    </thead>
                    <tbody>
                        ${data.map((hv, i) => `
                        <tr>
                            <td class="text-muted small">${i+1}</td>
                            <td>${hv.anhDaiDien
                                ? `<img src="${hv.anhDaiDien}" class="rounded-circle" style="width:32px;height:32px;object-fit:cover" alt="">`
                                : `<div class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center fw-bold" style="width:32px;height:32px;font-size:12px">${(hv.hoTen||'?').split(' ').pop()[0].toUpperCase()}</div>`
                            }</td>
                            <td class="fw-semibold">${hv.hoTen}</td>
                            <td><code>${hv.maHocVien}</code></td>
                            <td class="text-muted small">${hv.email}</td>
                            <td class="text-muted small">${hv.soDienThoai || '—'}</td>
                            <td><span class="badge bg-${statusColors[hv.trangThaiDangKy]||'secondary'}">${statusLabels[hv.trangThaiDangKy]||hv.trangThaiDangKy}</span></td>
                        </tr>`).join('')}
                    </tbody>
                </table>
            </div>`;
    } catch(e) {
        document.getElementById('hvListBody').innerHTML = `<div class="alert alert-danger">Lỗi tải danh sách học viên. Vui lòng đăng nhập.</div>`;
    }
}

async function dangKyKhoaHoc(id) {
    const token = localStorage.getItem('jwt_token');
    if (!token) { window.location.href = '/Auth/DangNhap'; return; }
    if (!confirm('Bạn muốn đăng ký khóa học này?\nSau khi đăng ký bạn sẽ được chuyển đến trang thanh toán.')) return;

    const btn = document.querySelector('[onclick="dangKyKhoaHoc(' + id + ')"]');
    if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang đăng ký...'; }

    const res = await apiCall('/api/hoc-vien/dang-ky-khoa-hoc', { method: 'POST', body: { khoaHocId: id, ghiChu: '' } });
    const d = await res.json();
    if (res.ok) {
        if (d.redirectUrl) {
            window.location.href = d.redirectUrl;
        } else {
            showToast('success', d.message);
            setTimeout(() => location.reload(), 1500);
        }
    } else {
        showToast('danger', d.message);
        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-plus-circle me-2"></i>Đăng ký ngay'; }
    }
}
</script>
}
