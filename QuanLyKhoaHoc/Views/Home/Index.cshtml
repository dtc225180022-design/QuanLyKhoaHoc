<!-- Khóa học nổi bật -->
@if (khoaHocMo.Any())
{
    <section class="py-5 bg-light">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold mb-1">Khóa học đang mở</h2>
                    <p class="text-muted mb-0">Đăng ký ngay để không bỏ lỡ</p>
                </div>
                <a href="/KhoaHoc" class="btn btn-outline-primary">Xem tất cả <i class="bi bi-arrow-right ms-1"></i></a>
            </div>
            <div class="row g-4">
                @foreach (var kh in khoaHocMo.Take(3))
                {
                    var soHv = kh.DanhSachDangKy.Count(d => d.TrangThai != QuanLyKhoaHoc.Models.TrangThaiDangKy.HuyBo);
                    var mauSac = kh.NgonNgu switch {
                        "Tiếng Anh" => "#0d6efd", "Tiếng Nhật" => "#dc3545",
                        "Tiếng Hàn" => "#fd7e14", "Tiếng Trung" => "#198754", _ => "#6c757d"
                    };
                    <div class="col-md-4">
                        <div class="card h-100 shadow-sm border-0 course-card" style="border-top:3px solid @mauSac!important">
                            <div class="card-body p-3">
                                <span class="badge text-white mb-2" style="background:@mauSac">@kh.NgonNgu</span>
                                <span class="badge bg-light text-dark border ms-1 mb-2">@kh.TrinhDo</span>
                                <h6 class="fw-bold">@kh.TenKhoaHoc</h6>
                                <p class="text-muted small">@(kh.MoTa.Length > 80 ? kh.MoTa[..80] + "…" : kh.MoTa)</p>
                                <div class="text-muted small">
                                    <i class="bi bi-calendar me-1"></i>@kh.NgayBatDau.ToString("dd/MM/yyyy")
                                    <span class="ms-3"><i class="bi bi-people me-1"></i>@soHv/@kh.SoLuongToiDa học viên</span>
                                </div>
                            </div>
                            <div class="card-footer border-0 bg-transparent d-flex justify-content-between align-items-center pb-3 px-3">
                                <span class="fw-bold text-primary">@kh.HocPhi.ToString("N0")₫</span>
                                <button class="btn btn-sm btn-primary" onclick="dangKyKhoaHoc(@kh.Id)">
                                    <i class="bi bi-plus-circle me-1"></i>Đăng ký
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

