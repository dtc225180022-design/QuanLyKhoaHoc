@section Scripts {
<script>
async function goiYAI() {
    const trinhDo = document.getElementById('aiTrinhDo').value;
    const ngonNgu = document.getElementById('aiNgonNgu').value;
    const res = await fetch(`/api/ai/goi-y?trinhDo=${encodeURIComponent(trinhDo)}&ngonNgu=${encodeURIComponent(ngonNgu)}`);
    const data = await res.json();
    renderAICards(data);
}

function renderAICards(data) {
    const colors = { 'Tiếng Anh': '#0d6efd', 'Tiếng Nhật': '#dc3545', 'Tiếng Hàn': '#fd7e14', 'Tiếng Trung': '#198754', 'Tiếng Pháp': '#6f42c1' };
    const section = document.getElementById('aiResultSection');
    const cards = document.getElementById('aiCards');
    if (!data.length) { section.style.display = 'none'; return; }
    section.style.display = '';
    cards.innerHTML = data.map(k => {
        const c = colors[k.ngonNgu] || '#6c757d';
        return `<div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm h-100" style="border-top:3px solid ${c}!important">
                <div class="card-body p-3">
                    <span class="badge text-white mb-2" style="background:${c}">${k.ngonNgu}</span>
                    <span class="badge bg-light text-dark border ms-1 mb-2">${k.trinhDo}</span>
                    ${(k.tags||[]).map(t=>`<span class="badge bg-warning text-dark mb-2 ms-1 small">${t}</span>`).join('')}
                    <h6 class="fw-bold">${k.tenKhoaHoc}</h6>
                    <p class="text-muted small">${k.lyDo || ''}</p>
                    <div class="fw-bold text-primary">${(k.hocPhi||0).toLocaleString('vi-VN')}₫</div>
                </div>
                <div class="card-footer border-0 bg-transparent pb-3 px-3">
                    <button class="btn btn-sm btn-primary w-100" onclick="dangKyKhoaHoc(${k.id})">
                        <i class="bi bi-plus-circle me-1"></i>Đăng ký
                    </button>
                </div>
            </div>
        </div>`;
    }).join('');
}

async function dangKyKhoaHoc(id) {
    const token = localStorage.getItem('jwt_token');
    if (!token) { window.location.href = '/Auth/DangNhap'; return; }
    if (!confirm('Bạn muốn đăng ký khóa học này?')) return;
    const res = await apiCall('/api/hoc-vien/dang-ky-khoa-hoc', { method: 'POST', body: { khoaHocId: id, ghiChu: '' } });
    const d = await res.json();
    showToast(res.ok ? 'success' : 'danger', d.message);
    if (res.ok) setTimeout(() => location.reload(), 1500);
}

// Load banner carousel
document.addEventListener('DOMContentLoaded', async () => {
    try {
        const res = await fetch('/api/banner');
        if (!res.ok) return;
        const banners = await res.json();
        if (!banners.length) return;
        const indicators = document.getElementById('carouselIndicators');
        const inner = document.getElementById('carouselInner');
        indicators.innerHTML = banners.map((b, i) =>
            `<button type="button" data-bs-target="#bannerCarousel" data-bs-slide-to="${i}" ${i===0?'class="active"':''}></button>`
        ).join('');
        inner.innerHTML = banners.map((b, i) => `
            <div class="carousel-item ${i===0?'active':''}">
                <img src="${b.hinhAnh}" class="d-block w-100" style="height:400px;object-fit:cover" alt="${b.tieuDe}" onerror="this.src='https://images.unsplash.com/photo-1456513080510-7bf3a84b82f8?w=1200&q=80'">
                <div class="carousel-caption d-none d-md-block" style="background:rgba(0,0,0,.4);border-radius:12px;padding:16px 24px">
                    <h4 class="fw-bold">${b.tieuDe}</h4>
                    <p class="mb-2 small">${b.moTa}</p>
                    ${b.duongDanLienKet ? `<a href="${b.duongDanLienKet}" class="btn btn-warning btn-sm fw-semibold">Tìm hiểu thêm <i class="bi bi-arrow-right ms-1"></i></a>` : ''}
                </div>
            </div>`).join('');
        document.getElementById('bannerSection').style.display = '';
    } catch(e) {}
});

// Load tin tức nổi bật
document.addEventListener('DOMContentLoaded', async () => {
    try {
        const res = await fetch('/api/bai-viet?noiBat=true&pageSize=3');
        if (!res.ok) return;
        const data = await res.json();
        const items = data.items || data;
        if (!items || !items.length) return;
        const section = document.getElementById('sectionTinTuc');
        const cards = document.getElementById('tinTucCards');
        cards.innerHTML = items.slice(0, 3).map(b => `
            <div class="col-md-4">
                <a href="/TinTuc/${b.id}" class="text-decoration-none text-dark">
                    <div class="card border-0 shadow-sm h-100 hover-shadow">
                        ${b.hinhAnh ? `<img src="${b.hinhAnh}" class="card-img-top" style="height:180px;object-fit:cover" alt="${b.tieuDe}" onerror="this.parentElement.removeChild(this)">` : `<div class="card-img-top bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="height:180px"><i class="bi bi-newspaper text-primary" style="font-size:3rem"></i></div>`}
                        <div class="card-body p-3">
                            <span class="badge bg-primary bg-opacity-10 text-primary small mb-2">${b.theLoai || 'Tin tức'}</span>
                            <h6 class="fw-bold mb-2 lh-sm">${b.tieuDe}</h6>
                            <p class="text-muted small mb-0 line-clamp-2">${b.tomTat || ''}</p>
                        </div>
                        <div class="card-footer bg-transparent border-0 d-flex justify-content-between align-items-center pt-0 pb-3 px-3">
                            <small class="text-muted"><i class="bi bi-person me-1"></i>${b.tacGia || 'EduCenter'}</small>
                            <small class="text-muted">${new Date(b.ngayTao).toLocaleDateString('vi-VN')}</small>
                        </div>
                    </div>
                </a>
            </div>`).join('');
        section.style.display = '';
    } catch(e) {}
});

// Load gợi ý cá nhân nếu đã đăng nhập
document.addEventListener('DOMContentLoaded', async () => {
    const token = localStorage.getItem('jwt_token');
    if (!token) return;

    const res = await apiCall('/api/ai/goi-y-cua-toi');
    if (!res.ok) return;
    const data = await res.json();
    if (!data.length) return;

    const section = document.getElementById('sectionGoiYCaNhan');
    const cards = document.getElementById('goiYCaNhanCards');
    const colors = { 'Tiếng Anh': '#0d6efd', 'Tiếng Nhật': '#dc3545', 'Tiếng Hàn': '#fd7e14', 'Tiếng Trung': '#198754', 'Tiếng Pháp': '#6f42c1' };

    cards.innerHTML = data.slice(0,4).map(k => {
        const c = colors[k.ngonNgu] || '#6c757d';
        return `<div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100" style="border-top:3px solid ${c}!important">
                <div class="card-body p-3">
                    <span class="badge text-white mb-2" style="background:${c}">${k.ngonNgu}</span>
                    ${(k.tags||[]).map(t=>`<span class="badge bg-warning text-dark ms-1 mb-2 small">${t}</span>`).join('')}
                    <h6 class="fw-bold">${k.tenKhoaHoc}</h6>
                    <p class="text-muted small">${k.lyDo || ''}</p>
                    <div class="fw-bold text-primary">${(k.hocPhi||0).toLocaleString('vi-VN')}₫</div>
                </div>
                <div class="card-footer border-0 bg-transparent pb-3 px-3">
                    <button class="btn btn-sm btn-primary w-100" onclick="dangKyKhoaHoc(${k.id})">
                        <i class="bi bi-plus-circle me-1"></i>Đăng ký
                    </button>
                </div>
            </div>
        </div>`;
    }).join('');
    section.style.display = '';
});
</script>
}
