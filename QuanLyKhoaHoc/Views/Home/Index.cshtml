@{
    ViewData["Title"] = "Trang chủ";
    var khoaHocMo = ViewBag.KhoaHocMo as List<QuanLyKhoaHoc.Models.KhoaHoc> ?? new();
}

<!-- Hero -->
<section class="hero-section text-white py-5">
    <div class="container py-4">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="badge bg-warning text-dark mb-3 px-3 py-2 rounded-pill">
                    <i class="bi bi-star-fill me-1"></i>Trung tâm ngoại ngữ hàng đầu Việt Nam
                </div>
                <h1 class="display-4 fw-bold mb-3">Mở cánh cửa thế giới với ngoại ngữ</h1>
                <p class="lead mb-4 text-white-50">Học cùng đội ngũ giảng viên chuyên nghiệp, lộ trình cá nhân hóa với AI, linh hoạt học offline & online.</p>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/KhoaHoc" class="btn btn-warning btn-lg fw-semibold shadow">
                        <i class="bi bi-search me-2"></i>Khám phá khóa học
                    </a>
                    <a href="/Auth/DangKy" class="btn btn-outline-light btn-lg">
                        <i class="bi bi-person-plus me-2"></i>Đăng ký học
                    </a>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-flex justify-content-center">
                <div class="position-relative">
                    <div class="bg-white bg-opacity-10 rounded-4 p-4 text-center" style="width:280px">
                        <div class="display-1 mb-2">🎓</div>
                        <div class="fw-bold fs-5">Học viên xuất sắc</div>
                        <div class="text-white-50 small">Cộng đồng học tập năng động</div>
                        <div class="d-flex justify-content-center gap-2 mt-3">
                            <span class="badge bg-warning text-dark">🇬🇧 Tiếng Anh</span>
                            <span class="badge bg-danger">🇯🇵 Tiếng Nhật</span>
                        </div>
                        <div class="d-flex justify-content-center gap-2 mt-2">
                            <span class="badge bg-warning text-dark">🇰🇷 Tiếng Hàn</span>
                            <span class="badge bg-success">🇨🇳 Tiếng Trung</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Banner Carousel -->
<section id="bannerSection" style="display:none">
    <div id="bannerCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="4500">
        <div class="carousel-indicators" id="carouselIndicators"></div>
        <div class="carousel-inner" id="carouselInner"></div>
        <button class="carousel-control-prev" type="button" data-bs-target="#bannerCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#bannerCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
</section>

<!-- Cam kết -->
<section class="bg-white py-5 shadow-sm">
    <div class="container">
        <div class="row text-center g-4">
            <div class="col-6 col-md-3">
                <div class="mb-3">
                    <div class="mx-auto d-flex align-items-center justify-content-center rounded-circle bg-warning bg-opacity-10" style="width:72px;height:72px">
                        <i class="bi bi-trophy-fill text-warning" style="font-size:2rem"></i>
                    </div>
                </div>
                <h6 class="fw-bold mb-1">Cam kết đầu ra</h6>
                <p class="text-muted small mb-0">Hoàn tiền nếu không đạt mục tiêu đã cam kết</p>
            </div>
            <div class="col-6 col-md-3">
                <div class="mb-3">
                    <div class="mx-auto d-flex align-items-center justify-content-center rounded-circle bg-primary bg-opacity-10" style="width:72px;height:72px">
                        <i class="bi bi-person-badge-fill text-primary" style="font-size:2rem"></i>
                    </div>
                </div>
                <h6 class="fw-bold mb-1">Giáo viên chuyên nghiệp</h6>
                <p class="text-muted small mb-0">100% thạc sĩ, kinh nghiệm thực tế tại nước ngoài</p>
            </div>
            <div class="col-6 col-md-3">
                <div class="mb-3">
                    <div class="mx-auto d-flex align-items-center justify-content-center rounded-circle bg-success bg-opacity-10" style="width:72px;height:72px">
                        <i class="bi bi-camera-video-fill text-success" style="font-size:2rem"></i>
                    </div>
                </div>
                <h6 class="fw-bold mb-1">Học Online &amp; Offline</h6>
                <p class="text-muted small mb-0">Linh hoạt học tại cơ sở hoặc qua Google Meet</p>
            </div>
            <div class="col-6 col-md-3">
                <div class="mb-3">
                    <div class="mx-auto d-flex align-items-center justify-content-center rounded-circle bg-danger bg-opacity-10" style="width:72px;height:72px">
                        <i class="bi bi-headset text-danger" style="font-size:2rem"></i>
                    </div>
                </div>
                <h6 class="fw-bold mb-1">Hỗ trợ 24/7</h6>
                <p class="text-muted small mb-0">Đội ngũ luôn sẵn sàng giải đáp mọi thắc mắc</p>
            </div>
        </div>
    </div>
</section>

<!-- AI Gợi ý khóa học (form cho khách + kết quả cho người đăng nhập) -->
<section class="py-5 bg-light">
    <div class="container">
        <!-- Form AI cho khách/người chưa có gợi ý cá nhân -->
        <div class="row justify-content-center mb-5">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm" style="background:linear-gradient(135deg,#0d6efd08,#0dcaf008)">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3 mb-4">
                            <div class="stat-icon bg-primary bg-opacity-10" style="width:56px;height:56px;border-radius:16px;display:flex;align-items:center;justify-content:center">
                                <i class="bi bi-robot text-primary fs-3"></i>
                            </div>
                            <div>
                                <h4 class="mb-0 fw-bold">AI Gợi Ý Khóa Học</h4>
                                <p class="text-muted mb-0 small">Nhập thông tin để nhận gợi ý phù hợp nhất</p>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label small fw-semibold">Trình độ hiện tại</label>
                                <select id="aiTrinhDo" class="form-select">
                                    <option value="">Chọn trình độ</option>
                                    <option value="Căn bản">Mới bắt đầu (A1-A2)</option>
                                    <option value="Trung cấp">Sơ trung cấp (B1)</option>
                                    <option value="Nâng cao">Trung cao cấp (B2-C1)</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-semibold">Ngôn ngữ muốn học</label>
                                <select id="aiNgonNgu" class="form-select">
                                    <option value="">Tất cả</option>
                                    <option value="Tiếng Anh">🇬🇧 Tiếng Anh</option>
                                    <option value="Tiếng Nhật">🇯🇵 Tiếng Nhật</option>
                                    <option value="Tiếng Hàn">🇰🇷 Tiếng Hàn</option>
                                    <option value="Tiếng Trung">🇨🇳 Tiếng Trung</option>
                                    <option value="Tiếng Pháp">🇫🇷 Tiếng Pháp</option>
                                </select>
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <button class="btn btn-primary w-100 fw-semibold" onclick="goiYAI()">
                                    <i class="bi bi-stars me-2"></i>Gợi ý cho tôi
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Kết quả AI -->
        <div id="aiResultSection" style="display:none">
            <h5 class="fw-bold mb-3 text-center"><i class="bi bi-stars text-warning me-2"></i>Khóa học gợi ý cho bạn</h5>
            <div class="row g-3" id="aiCards"></div>
        </div>

        <!-- Gợi ý cá nhân (khi đã đăng nhập) -->
        <div id="sectionGoiYCaNhan" style="display:none">
            <h5 class="fw-bold mb-3"><i class="bi bi-person-check text-primary me-2"></i>Gợi ý dựa trên hồ sơ của bạn</h5>
            <div class="row g-3" id="goiYCaNhanCards"></div>
        </div>
    </div>
</section>

<!-- Tại sao chọn EduCenter -->
